{
  "manifest_version": 3,
  "name": "DLsite Dashboard Capture",
  "version": "1.0.0",
  "description": "DLsiteの作品データを自動取得してFirebaseに保存します",
  "permissions": [
    "storage",
    "tabs",
    "identity",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.dlsite.com/*",
    "https://*.firebaseio.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DLsite Dashboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.dlsite.com/*/work/=/product_id/*",
        "https://www.dlsite.com/*/work/announce/=/product_id/*"
      ],
      "js": ["content-work.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.dlsite.com/home/mypage/*",
        "https://www.dlsite.com/home/work/create/*",
        "https://manage.dlsite.com/*"
      ],
      "js": ["content-manage.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
